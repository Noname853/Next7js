# Salin file ini menjadi .env, lalu isi nilainya.
# JANGAN commit .env ke git.

# Prisma datasource. Default SQLite untuk dev.
DATABASE_URL="file:./dev.db"

# Secret untuk NextAuth/JWT. Generate dengan: openssl rand -base64 32
# WAJIB di-set. Tanpa nilai, aplikasi akan gagal start.
AUTH_SECRET=

# URL public aplikasi (dipakai NextAuth untuk callback).
NEXTAUTH_URL="http://localhost:3000"
